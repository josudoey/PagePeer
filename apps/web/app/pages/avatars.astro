---
import '../styles/global.css'
import AvatarGallery from '../components/P2PShare/AvatarGallery'
---

<!doctype html>
<html lang='zh-Hant' class='scroll-smooth'>
  <head>
    <!-- Google Tag Manager -->
    {import.meta.env.PROD && (
      <script is:inline>
        (function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
        new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
        j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
        'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
        })(window,document,'script','dataLayer','GTM-MBGWG2SH');
      </script>
    )}
    <!-- End Google Tag Manager -->
    <meta charset='utf-8' />
    <link rel='icon' type='image/svg+xml' href='/favicon.svg' />
    <meta
      name='viewport'
      content='width=device-width, initial-scale=1, viewport-fit=cover'
    />
    <meta name='generator' content={Astro.generator} />
    <meta
      name='description'
      content='PagePeer Avatar 預覽與檢視面板。'
    />
    <title>PagePeer | Avatar 預覽面板</title>

    <!-- Google Fonts -->
    <link rel='preconnect' href='https://fonts.googleapis.com' />
    <link rel='preconnect' href='https://fonts.gstatic.com' crossorigin />
    <link
      href='https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Outfit:wght@400;600;800&display=swap'
      rel='stylesheet'
    />

    <style>
      body {
        font-family:
          'Inter',
          'Outfit',
          system-ui,
          -apple-system,
          sans-serif;
      }
      .font-title {
        font-family: 'Outfit', sans-serif;
      }
    </style>
  </head>
  <body
    class='bg-slate-50 text-slate-800 flex flex-col min-h-screen relative overflow-x-hidden'
  >
    <!-- Google Tag Manager (noscript) -->
    {import.meta.env.PROD && (
      <noscript>
        <iframe
          src="https://www.googletagmanager.com/ns.html?id=GTM-MBGWG2SH"
          height="0"
          width="0"
          style="display:none;visibility:hidden"
        ></iframe>
      </noscript>
    )}
    <!-- End Google Tag Manager (noscript) -->

    <!-- Background Decorative Gradients -->
    <div
      class='absolute top-[-20%] left-[-10%] w-[50vw] h-[50vw] rounded-full bg-cyan-500/5 blur-[120px] pointer-events-none'
    >
    </div>
    <div
      class='absolute bottom-[-10%] right-[-10%] w-[60vw] h-[60vw] rounded-full bg-blue-600/5 blur-[150px] pointer-events-none'
    >
    </div>

    <!-- Main Content -->
    <main class='w-full flex-grow z-10'>
      <AvatarGallery client:only="react" />
    </main>
  </body>
</html>
