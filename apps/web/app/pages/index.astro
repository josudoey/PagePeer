---
import '../styles/global.css'
import Counter from '../components/Counter'
---

<!doctype html>
<html lang='zh-Hant' class='scroll-smooth'>
  <head>
    <meta charset='utf-8' />
    <link rel='icon' type='image/svg+xml' href='/favicon.svg' />
    <meta name='viewport' content='width=device-width, initial-scale=1.0' />
    <meta name='generator' content={Astro.generator} />
    <meta
      name='description'
      content='Astro + React + Tailwind CSS 現代化網頁應用程式基本專案範本。包含極致視覺設計與互動式元件展示。'
    />
    <title>PagePeer - Astro + React + Tailwind CSS 專案</title>

    <!-- Google Fonts -->
    <link rel='preconnect' href='https://fonts.googleapis.com' />
    <link rel='preconnect' href='https://fonts.gstatic.com' crossorigin />
    <link
      href='https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Outfit:wght@400;600;800&display=swap'
      rel='stylesheet'
    />

    <style>
      body {
        font-family:
          'Inter',
          'Outfit',
          system-ui,
          -apple-system,
          sans-serif;
      }
      .font-title {
        font-family: 'Outfit', sans-serif;
      }
    </style>
  </head>
  <body
    class='bg-[#0b0f19] text-slate-100 min-h-screen flex flex-col justify-between overflow-x-hidden relative'
  >
    <!-- Background Decorative Gradients -->
    <div
      class='absolute top-[-20%] left-[-10%] w-[50vw] h-[50vw] rounded-full bg-cyan-500/10 blur-[120px] pointer-events-none'
    >
    </div>
    <div
      class='absolute bottom-[-10%] right-[-10%] w-[60vw] h-[60vw] rounded-full bg-blue-600/10 blur-[150px] pointer-events-none'
    >
    </div>

    <!-- Header / Navigation -->
    <header
      class='w-full max-w-7xl mx-auto px-6 py-6 flex justify-between items-center z-10'
    >
      <div class='flex items-center gap-2'>
        <span
          class='text-2xl font-black font-title tracking-tight text-transparent bg-clip-text bg-gradient-to-r from-cyan-400 to-blue-500'
        >
          PagePeer
        </span>
        <span
          class='px-2 py-0.5 text-[10px] font-bold tracking-widest text-cyan-400 bg-cyan-950/50 rounded-full border border-cyan-800/40'
        >
          V3
        </span>
      </div>

      <nav>
        <ul class='flex gap-6 text-sm font-medium text-slate-400'>
          <li>
            <a
              href='https://astro.build'
              target='_blank'
              rel='noopener noreferrer'
              class='hover:text-cyan-400 transition-colors'>Astro Docs</a
            >
          </li>
          <li>
            <a
              href='https://react.dev'
              target='_blank'
              rel='noopener noreferrer'
              class='hover:text-cyan-400 transition-colors'>React</a
            >
          </li>
          <li>
            <a
              href='https://tailwindcss.com'
              target='_blank'
              rel='noopener noreferrer'
              class='hover:text-cyan-400 transition-colors'>Tailwind CSS</a
            >
          </li>
        </ul>
      </nav>
    </header>

    <!-- Main Hero Section -->
    <main
      class='flex-grow flex flex-col items-center justify-center px-6 py-12 z-10'
    >
      <div class='max-w-4xl w-full text-center flex flex-col items-center'>
        <!-- Tagline Badge -->
        <div
          class='inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-white/5 border border-white/10 text-xs text-slate-300 mb-8 animate-fade-in'
        >
          <span class='flex h-2 w-2 relative'>
            <span
              class='animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75'
            ></span>
            <span
              class='relative inline-flex rounded-full h-2 w-2 bg-emerald-500'
            ></span>
          </span>
          基本專案已成功部署與配置
        </div>

        <!-- Main Heading -->
        <h1
          class='text-4xl md:text-6xl lg:text-7xl font-extrabold font-title tracking-tight text-white mb-6 leading-tight'
        >
          Astro 遇上 <br class='sm:hidden' />
          <span
            class='text-transparent bg-clip-text bg-gradient-to-r from-cyan-400 via-sky-400 to-blue-500'
          >
            React & Tailwind
          </span>
        </h1>

        <!-- Subtitle Description -->
        <p
          class='text-base md:text-lg text-slate-400 max-w-2xl mb-12 leading-relaxed'
        >
          這是一個極速、現代化且為效能最佳化的基礎專案。結合了 <strong
            class='text-slate-200'>Astro 6</strong
          > 的極簡靜態優勢、<strong class='text-slate-200'>React 19</strong> 的強大動態互動元件，以及由
          <strong class='text-slate-200'>Tailwind v4 (Vite)</strong> 驅動的絕佳樣式。
        </p>

        <!-- Grid Layout for Features & Interactive Card -->
        <div
          class='grid md:grid-cols-2 gap-8 max-w-3xl w-full items-center text-left'
        >
          <!-- Left: Feature Bullet Points -->
          <div class='space-y-6'>
            <h2
              class='text-xl font-bold font-title text-white tracking-wide border-b border-slate-800 pb-3'
            >
              專案核心技術
            </h2>

            <ul class='space-y-4'>
              <li class='flex items-start gap-3'>
                <span
                  class='mt-1 flex-shrink-0 w-5 h-5 rounded-md bg-cyan-950 flex items-center justify-center border border-cyan-800 text-cyan-400 text-xs font-bold'
                  >✓</span
                >
                <div>
                  <h3 class='text-sm font-semibold text-slate-200'>
                    Astro 孤島架構 (Islands)
                  </h3>
                  <p class='text-xs text-slate-400 mt-0.5'>
                    預設生成零 JavaScript 的靜態 HTML，只在需要交互的元件注入
                    React 水合。
                  </p>
                </div>
              </li>
              <li class='flex items-start gap-3'>
                <span
                  class='mt-1 flex-shrink-0 w-5 h-5 rounded-md bg-cyan-950 flex items-center justify-center border border-cyan-800 text-cyan-400 text-xs font-bold'
                  >✓</span
                >
                <div>
                  <h3 class='text-sm font-semibold text-slate-200'>
                    Tailwind CSS v4 (Vite)
                  </h3>
                  <p class='text-xs text-slate-400 mt-0.5'>
                    極致的編譯速度，並支援最新 CSS 語法，完美無縫整合於 Vite
                    建置流程。
                  </p>
                </div>
              </li>
              <li class='flex items-start gap-3'>
                <span
                  class='mt-1 flex-shrink-0 w-5 h-5 rounded-md bg-cyan-950 flex items-center justify-center border border-cyan-800 text-cyan-400 text-xs font-bold'
                  >✓</span
                >
                <div>
                  <h3 class='text-sm font-semibold text-slate-200'>
                    pnpm Workspaces
                  </h3>
                  <p class='text-xs text-slate-400 mt-0.5'>
                    使用 monorepo 管理專案目錄，利於未來與其他應用程式（如
                    admin, api）共用模組。
                  </p>
                </div>
              </li>
            </ul>
          </div>

          <!-- Right: React Interactive Counter Card -->
          <div class='w-full flex justify-center'>
            <div id='interactive-counter-container' class='w-full max-w-sm'>
              <Counter client:load />
            </div>
          </div>
        </div>
      </div>
    </main>

    <!-- Footer -->
    <footer
      class='w-full border-t border-slate-900 py-6 mt-12 z-10 bg-[#070a12]/80 backdrop-blur-md'
    >
      <div
        class='max-w-7xl mx-auto px-6 flex flex-col sm:flex-row justify-between items-center gap-4 text-xs text-slate-500'
      >
        <p>
          © {new Date().getFullYear()} PagePeer Project. Built with passion & speed.
        </p>
        <p>Powered by Astro, React, and Tailwind CSS.</p>
      </div>
    </footer>
  </body>
</html>
